{
  "name": "Claudy - Instagram DM Assistant",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22",
  "features": {},
  "postCreateCommand": "cd apps/claudy && npm install",
  "postStartCommand": "cd apps/claudy && npm run dev",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Claudy Webhook Server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
